# Database
POSTGRES_DB=article_index
POSTGRES_USER=article_index
POSTGRES_PASSWORD=article_index
POSTGRES_PORT=5432

# Internal container-to-container URLs
DATABASE_URL=postgresql://article_index:article_index@db:5432/article_index
REDIS_URL=redis://redis:6379/0

# Exposed host ports
REDIS_PORT=6380
API_PORT=8001

# API auth
API_KEY=change-me-long-random

# Ollama
OLLAMA_HOST=http://host.docker.internal:11434
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_CHAT_MODEL=llama3.2

# RAG
RAG_SIMILARITY_THRESHOLD=0.7
RAG_CONTEXT_LIMIT=5

# Logging
LOG_LEVEL=INFO

# Worker
MAX_CONCURRENT_PROCESSING=3
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1