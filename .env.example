# Database
POSTGRES_DB=article_index
POSTGRES_USER=article_index
POSTGRES_PASSWORD=article_index
POSTGRES_PORT=5432

# Internal container-to-container URLs
DATABASE_URL=postgresql://article_index:article_index@db:5432/article_index
REDIS_URL=redis://redis:6379/0

# Exposed host ports
REDIS_PORT=6380
API_PORT=8001
FLOWER_PORT=5555

# API auth
API_KEY=change-me-long-random

# Ollama
OLLAMA_HOST=http://host.docker.internal:11434
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_CHAT_MODEL=llama3.2

# RAG
RAG_SIMILARITY_THRESHOLD=0.7
RAG_CONTEXT_LIMIT=5

# Logging
LOG_LEVEL=INFO

# Worker
MAX_CONCURRENT_PROCESSING=3
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Hybrid Search Configuration
# Set to 'true' to make hybrid search the default for /rag endpoint
USE_HYBRID_RAG=false

# Weight configuration for score blending (must sum to 1.0)
HYBRID_LEXICAL_WEIGHT=0.35
HYBRID_SEMANTIC_WEIGHT=0.65

# Candidate pool sizes for each search type
HYBRID_LEXICAL_LIMIT=30
HYBRID_VECTOR_LIMIT=40

# Hybrid Ranking Mode: 'weighted' or 'rrf'
# weighted: Score blending (lexical_weight * lexical_score + semantic_weight * semantic_score)
# rrf: Reciprocal Rank Fusion (1/(k + rank) from each source)
# Recommendation: Run `python scripts/benchmark_hnsw.py --compare-ranking` to determine best mode
HYBRID_RANKING_MODE=weighted

# RRF configuration (only used when HYBRID_RANKING_MODE=rrf)
HYBRID_RRF_K=60

# Auto-adjust weights for exact-term queries (versions, acronyms, etc.)
# Only applies to weighted mode
HYBRID_AUTO_TUNE_WEIGHTS=true

# Context Builder Configuration
CONTEXT_MAX_TOKENS=3000
CONTEXT_MAX_PER_DOCUMENT=2
CONTEXT_COLLAPSE_ADJACENT=true
CONTEXT_INCLUDE_CITATIONS=true

# HNSW Vector Index Configuration
# ef_search controls the exploration factor at query time
# Higher = better recall, slower queries (range: 1-1000)
HNSW_EF_SEARCH=40

# Query Transformation Configuration
# Modes: off | always | selective
#   off:      No transformation (fastest, default)
#   always:   Always transform (higher recall, more latency)
#   selective: Transform only ambiguous/complex queries (balanced)
QUERY_TRANSFORM_MODE=off

# Maximum number of queries to generate (2-5 recommended)
QUERY_TRANSFORM_MAX_QUERIES=3

# Enable specific transformation strategies
QUERY_TRANSFORM_MULTIQUERY=true
QUERY_TRANSFORM_STEPBACK=true

# Selective mode triggers
QUERY_TRANSFORM_MIN_WORDS=4
QUERY_TRANSFORM_AMBIGUITY=1

# Latency budget in milliseconds (skip remaining expansions if exceeded)
QUERY_TRANSFORM_LATENCY_BUDGET_MS=150

# Evidence-Aware Retrieval Configuration (Phase 9)
# Modes: off | always | selective
#   off:      No filtering (fastest, default)
#   always:   Always filter context (highest quality)
#   selective: Filter based on context quality (balanced)
EVIDENCE_AWARE_MODE=off

# Context filtering parameters
CONTEXT_FILTER_ENABLED=true
CONTEXT_DEDUP_THRESHOLD=0.85
CONTEXT_MAX_PER_DOC=2
CONTEXT_MIN_SCORE=0.3
CONTEXT_MAX_CHUNKS=8
CONTEXT_FILTER_BOILERPLATE=true

# Evidence scoring parameters
RETRIEVAL_CONFIDENCE_ENABLED=true

# Reranker Configuration
# Modes: off | always | selective
#   off:      Never rerank (fastest, default)
#   always:   Always rerank all queries (highest quality, slowest)
#   selective: Rerank only "hard" queries based on triggers (balanced)
# Benchmark first: python scripts/benchmark_hnsw.py --compare-reranking
RERANK_MODE=off

# Legacy: RERANK_ENABLED=true maps to RERANK_MODE=always
# RERANK_ENABLED=false

# Number of candidates to retrieve for reranking
# More candidates = better reranking but higher latency
RERANK_TOP_N=30

# Number of results to return after reranking
RERANK_FINAL_K=10

# Reranking model/strategy
# cross_encoder: Uses LLM to score query-chunk relevance (slower, more accurate)
# embedding: Uses embedding similarity (faster, less accurate)
RERANK_MODEL=cross_encoder

# Use cross-encoder (True) or embedding similarity (False)
# Cross-encoder is more accurate but adds latency
RERANK_USE_CROSS_ENCODER=true

# Selective Reranking Triggers (only used when RERANK_MODE=selective)
# These thresholds determine when a query is "hard" enough to need reranking

# Score gap: Rerank when gap between rank 1 and rank 5 is below this threshold
# Smaller gap = more uncertainty = more benefit from reranking
RERANK_SCORE_GAP=0.03

# Ranking disagreement: Rerank when lexical and semantic rankings diverge
# Higher values mean more disagreement required to trigger reranking
RERANK_DISAGREEMENT=0.40

# Low evidence: Rerank when top result's score is below this threshold
RERANK_MIN_TOP_SCORE=0.55

# Query complexity: Rerank when query has at least this many words
# or contains complex patterns (comparisons, explanations, etc.)
RERANK_COMPLEX_QUERY_WORDS=12

# Phase 2: Confidence-Driven Control Loop
# These thresholds determine execution path routing based on confidence bands

# Confidence band thresholds (0.0 - 1.0)
# Query confidence is scored based on evidence strength, diversity, agreement, etc.
CONFIDENCE_HIGH=0.85        # >= 0.85: Fast path (direct generation, no reranking)
CONFIDENCE_MEDIUM=0.65      # 0.65-0.84: Standard path (conditional reranking)
CONFIDENCE_LOW=0.45         # 0.45-0.64: Cautious path (mandatory reranking + expansion)
                            # < 0.45: Abstain path (no generation, return error)

# Standard path uncertainty detection gates
# These gates determine whether medium-confidence queries need reranking

# Score gap threshold: If top1-top2 score gap < this, invoke reranker
# Smaller gap = more uncertainty = trigger reranking
UNCERTAINTY_SCORE_GAP_THRESHOLD=0.15

# Top strength threshold: If top-1 score < this, invoke reranker
# Lower top score = weaker evidence = trigger reranking
UNCERTAINTY_MIN_TOP_STRENGTH=0.6
